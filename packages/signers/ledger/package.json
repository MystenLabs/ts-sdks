{
	"name": "@mysten/ledger-signer",
	"author": "Mysten Labs <build@mystenlabs.com>",
	"description": "Sui signer for Ledger hardware wallets",
	"homepage": "https://sdk.mystenlabs.com",
	"version": "0.2.2",
	"license": "Apache-2.0",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"CHANGELOG.md",
		"LICENSE",
		"README.md",
		"dist",
		"src"
	],
	"scripts": {
		"clean": "rm -rf tsconfig.tsbuildinfo ./dist",
		"build": "rm -rf dist && tsc --noEmit && tsdown",
		"prettier:check": "prettier -c --ignore-unknown .",
		"prettier:fix": "prettier -w --ignore-unknown .",
		"oxlint:check": "oxlint  .",
		"oxlint:fix": "oxlint --fix",
		"lint": "pnpm run oxlint:check && pnpm run prettier:check",
		"lint:fix": "pnpm run oxlint:fix && pnpm run prettier:fix",
		"test": "vitest run --passWithNoTests"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MystenLabs/ts-sdks.git"
	},
	"bugs": {
		"url": "https://github.com/mystenlabs/ts-sdks/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@mysten/ledgerjs-hw-app-sui": "workspace:^"
	},
	"peerDependencies": {
		"@mysten/sui": "workspace:^"
	},
	"devDependencies": {
		"@types/node": "^25.9.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
