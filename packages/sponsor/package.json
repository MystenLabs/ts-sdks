{
	"name": "@mysten-incubation/sponsor",
	"version": "0.0.1",
	"private": false,
	"description": "Build Sui gas sponsorship flows from a signer, with pluggable transaction validation",
	"license": "Apache-2.0",
	"author": "Mysten Labs <build@mystenlabs.com>",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		}
	},
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"CHANGELOG.md",
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MystenLabs/ts-sdks.git"
	},
	"bugs": {
		"url": "https://github.com/MystenLabs/ts-sdks/issues/new"
	},
	"homepage": "https://github.com/MystenLabs/ts-sdks/tree/main/packages/sponsor#readme",
	"scripts": {
		"clean": "rm -rf tsconfig.tsbuildinfo ./dist",
		"build": "rm -rf dist && tsc --noEmit && tsdown",
		"prettier:check": "prettier -c --ignore-unknown .",
		"prettier:fix": "prettier -w --ignore-unknown .",
		"oxlint:check": "oxlint  .",
		"oxlint:fix": "oxlint --fix",
		"lint": "pnpm run oxlint:check && pnpm run prettier:check",
		"lint:fix": "pnpm run oxlint:fix && pnpm run prettier:fix",
		"test": "pnpm run test:typecheck && pnpm run test:unit",
		"test:typecheck": "tsc -p ./test",
		"test:unit": "vitest run",
		"test:e2e": "vitest run --config test/e2e/vitest.config.ts",
		"vitest": "vitest"
	},
	"devDependencies": {
		"@types/node": "^25.0.8",
		"typescript": "^5.9.3",
		"vitest": "^4.0.17"
	},
	"dependencies": {
		"@mysten/wallet-sdk": "workspace:^"
	},
	"peerDependencies": {
		"@mysten/sui": "workspace:^"
	}
}
